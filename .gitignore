# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environment
.venv/
venv/
env/

# IDE
.vscode/
!.vscode/mcp.json
.idea/
vscode-extension/node_modules/
vscode-extension/out/
vscode-extension/bundled/tool/
vscode-extension/*.vsix

# OS
.DS_Store
Thumbs.db
desktop.ini

# Data (per git-workflow bylaw §4)
data/rawdata/
data/jobs/
data/reports/

# Project artifacts from testing (not source-controlled)
data/projects/*/artifacts/
data/projects/*/figures/
data/projects/*/decision_log.jsonl
data/projects/*/deviation_log.jsonl

# Keep project configs (yaml/json) trackable
!data/projects/*.json

# Runtime-generated short-ID project metadata stays local
data/projects/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f].json

# Test artifacts
test_*.py
!tests/**
tests/**/__pycache__/
tests/**/*.py[cod]

# Temporary files
*.tmp
*.bak
*.py.bak
*.swp
*~
.tools/
uv.lock

# xhtml2pdf / reportlab caches
.cache/

# Internal local-only datasets
